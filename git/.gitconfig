[includeIf "gitdir:github/"]
  path = ~/.gitconfig-hub
[includeIf "gitdir:personal/"]
  path = ~/.gitconfig-lab

[core]
	editor = nvim
[mergetool "vimdiff"]
	path = nvim
[diff]
	tool = vimdiff
[merge]
	tool = vimdiff

[user]
	name = Jeff Wade
	email = jeffwade@users.noreply.github.com
[init]
	defaultBranch = main
[credential]
	helper = 
	helper = /usr/local/bin/git-credential-manager
[filter "lfs"]
	required = true
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
[credential "https://dev.azure.com"]
	useHttpPath = true
