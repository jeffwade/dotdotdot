[includeIf "gitdir:github/"]
  path = ~/.gitconfig-hub
[includeIf "gitdir:personal/"]
  path = ~/.gitconfig-lab

[core]
	editor = nvim
[mergetool "vimdiff"]
	path = nvim
[diff]
	tool = vimdiff
[merge]
	tool = vimdiff

[user]
	name = Jeff Wade
	email = jeffwade@users.noreply.github.com
[init]
	defaultBranch = main
[credential]
	helper = /usr/local/share/gcm-core/git-credential-manager
[credential "https://dev.azure.com"]
	useHttpPath = true
